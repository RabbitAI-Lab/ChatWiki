# Stage 1: 全量依赖（含 devDeps，用于 build）
FROM node:20-bookworm-slim AS deps
RUN corepack enable && corepack prepare pnpm@10.14.0 --activate
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 make g++ \
 && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY package.json ./
RUN pnpm install --no-frozen-lockfile

# Stage 2: 构建
FROM node:20-bookworm-slim AS builder
RUN corepack enable && corepack prepare pnpm@10.14.0 --activate
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
ENV NEXT_TELEMETRY_DISABLED=1
RUN pnpm build

# Stage 2.5: 裁剪为生产依赖
FROM builder AS prod-deps
RUN pnpm config set ignore-scripts true && pnpm prune --prod && \
    node -e "const fs=require('fs'),path=require('path'),cp=require('child_process');const base='.next/node_modules';if(!fs.statSync(base).isDirectory())process.exit(0);const entries=[];for(const n of fs.readdirSync(base)){const p=path.join(base,n);if(n.startsWith('@')){try{for(const s of fs.readdirSync(p))entries.push(path.join(p,s))}catch{}}else entries.push(p)}for(const e of entries){let st;try{st=fs.lstatSync(e)}catch{continue}if(!st.isSymbolicLink())continue;if(fs.existsSync(e))continue;const old=fs.readlinkSync(e);const i=old.lastIndexOf('node_modules/');if(i<0)continue;const pkg=old.slice(i+13);if(!pkg)continue;const r=cp.spawnSync('find',['node_modules/.pnpm','-path','*/node_modules/'+pkg],{encoding:'utf8',timeout:30000});const lines=(r.stdout||'').trim().split('\n');let fixed=false;for(const line of lines){if(!line)continue;const newRel=path.relative(path.dirname(e),line);fs.unlinkSync(e);fs.symlinkSync(newRel,e);console.log('Fixed:',e,'->',newRel);fixed=true;break}if(!fixed)console.log('WARN:not found:',pkg)}"

# Stage 3: 运行时
FROM node:20-bookworm-slim AS runner
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 make g++ bubblewrap socat curl ca-certificates \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# 安装 claude CLI（用于 Skills 功能）
RUN curl -fsSL https://claude.ai/install.sh | bash \
 && cp /root/.local/bin/claude /usr/local/bin/claude \
 && chmod +x /usr/local/bin/claude

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV MCP_PORT=4001
ENV MCP_HOST=0.0.0.0
ENV HOSTNAME=0.0.0.0

# 非 root 用户
RUN groupadd --system --gid 1001 nodejs \
 && useradd --system --uid 1001 --gid nodejs nextjs

# 复制构建产物与精简依赖
COPY --from=prod-deps --chown=nextjs:nodejs /app/node_modules ./node_modules
COPY --from=prod-deps --chown=nextjs:nodejs /app/package.json  ./package.json
COPY --from=prod-deps --chown=nextjs:nodejs /app/.next    ./.next
COPY --from=builder   --chown=nextjs:nodejs /app/public   ./public
COPY --from=builder   --chown=nextjs:nodejs /app/drizzle  ./drizzle
COPY --from=builder   --chown=nextjs:nodejs /app/vendor   ./vendor

# 预创建数据目录
RUN mkdir -p /app/data/home \
 && chown -R nextjs:nodejs /app/data

USER nextjs

EXPOSE 3000 4001

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD node -e "require('http').get('http://127.0.0.1:3000',r=>process.exit(r.statusCode<500?0:1)).on('error',()=>process.exit(1))"

CMD ["node", "node_modules/next/dist/bin/next", "start", "--hostname", "0.0.0.0"]
